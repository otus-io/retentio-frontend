#!/bin/bash

# =============================================================================
# Pre-commit hook for WordUpX
# Runs format checks and tests for changed files before allowing commits.
# Only checks backend or frontend if relevant files were modified.
# =============================================================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit checks..."
echo ""

# Detect which areas have staged changes
BACKEND_CHANGED=$(git diff --cached --name-only -- 'backend-api/' | head -1)
FRONTEND_CHANGED=$(git diff --cached --name-only -- 'frontend/' | head -1)
# Exclude auto-generated swagger.yaml from YAML lint
YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.yml' '*.yaml' | grep -v 'backend-api/docs/swagger.yaml' || true)
MD_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.md' '*.mdc' || true)

FAILED=0

# =============================================================================
# YAML lint (only if .yml/.yaml files changed)
# =============================================================================
if [ -n "$YAML_FILES" ]; then
    echo -e "${YELLOW}━━━ YAML Checks ━━━${NC}"
    echo "📋 Linting YAML files..."

    if command -v yamllint &> /dev/null; then
        YAML_FAILED=0
        for file in $YAML_FILES; do
            if yamllint -d "{extends: default, rules: {line-length: {max: 200}, truthy: disable}}" "$file" 2>&1; then
                echo -e "${GREEN}  ✓ $file${NC}"
            else
                YAML_FAILED=1
            fi
        done
        if [ $YAML_FAILED -ne 0 ]; then
            echo -e "${RED}  ✗ YAML lint issues found${NC}"
            FAILED=1
        else
            echo -e "${GREEN}  ✓ All YAML files OK${NC}"
        fi
    else
        echo -e "${YELLOW}  ⚠ yamllint not found — skipping (install: pip install yamllint)${NC}"
    fi

    echo ""
fi

# =============================================================================
# Markdown lint (only if .md/.mdc files changed)
# =============================================================================
if [ -n "$MD_FILES" ]; then
    echo -e "${YELLOW}━━━ Markdown Checks ━━━${NC}"
    echo "📋 Linting Markdown files..."

    if command -v markdownlint &> /dev/null; then
        if markdownlint --config .markdownlint.json $MD_FILES 2>&1; then
            echo -e "${GREEN}  ✓ Markdown lint OK${NC}"
        else
            echo -e "${RED}  ✗ Markdown lint issues found${NC}"
            FAILED=1
        fi
    elif command -v markdownlint-cli2 &> /dev/null; then
        if markdownlint-cli2 $MD_FILES 2>&1; then
            echo -e "${GREEN}  ✓ Markdown lint OK${NC}"
        else
            echo -e "${RED}  ✗ Markdown lint issues found${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  ⚠ markdownlint not found — skipping (install: npm install -g markdownlint-cli)${NC}"
    fi

    echo ""
fi

# =============================================================================
# Backend checks (only if backend files changed)
# =============================================================================
if [ -n "$BACKEND_CHANGED" ]; then
    echo -e "${YELLOW}━━━ Backend Checks ━━━${NC}"

    # --- Swagger docs generation ---
    echo "📝 Generating Swagger docs..."
    cd backend-api || exit 1
    if make swagger-prod; then
        git add docs/
        git add main.go
        echo -e "${GREEN}  ✓ Swagger docs updated and staged${NC}"
    else
        echo -e "${RED}  ✗ Swagger doc generation failed${NC}"
        FAILED=1
    fi
    cd ..

    # --- gofmt check ---
    echo "🔧 Checking Go formatting..."
    UNFORMATTED=$(gofmt -l backend-api/)
    if [ -z "$UNFORMATTED" ]; then
        echo -e "${GREEN}  ✓ Go formatting OK${NC}"
    else
        echo -e "${RED}  ✗ Go formatting issues found:${NC}"
        echo "$UNFORMATTED"
        echo "  Run: gofmt -w backend-api/"
        FAILED=1
    fi

    # --- go vet ---
    echo "🔎 Running go vet..."
    if (cd backend-api && go vet ./...); then
        echo -e "${GREEN}  ✓ go vet OK${NC}"
    else
        echo -e "${RED}  ✗ go vet found issues${NC}"
        FAILED=1
    fi

    # --- golangci-lint ---
    echo "🔎 Running golangci-lint..."
    if command -v golangci-lint &> /dev/null; then
        if (cd backend-api && golangci-lint run ./...); then
            echo -e "${GREEN}  ✓ golangci-lint OK${NC}"
        else
            echo -e "${RED}  ✗ golangci-lint found issues${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  ⚠ golangci-lint not found — skipping (install: https://golangci-lint.run/welcome/install/)${NC}"
    fi

    # --- go build ---
    echo "🔨 Checking Go build..."
    if (cd backend-api && go build ./...); then
        echo -e "${GREEN}  ✓ Go build OK${NC}"
    else
        echo -e "${RED}  ✗ Go build failed${NC}"
        FAILED=1
    fi

    # --- go test (unit) ---
    echo "🧪 Running Go unit tests..."
    if (cd backend-api && go test ./tests/unit/... 2>&1); then
        echo -e "${GREEN}  ✓ Go unit tests passed${NC}"
    else
        echo -e "${RED}  ✗ Go unit tests failed${NC}"
        FAILED=1
    fi

    # --- go test (integration) ---
    echo "🧪 Running Go integration tests..."
    if (cd backend-api && go test ./tests/integration/... 2>&1); then
        echo -e "${GREEN}  ✓ Go integration tests passed${NC}"
    else
        echo -e "${RED}  ✗ Go integration tests failed${NC}"
        FAILED=1
    fi

    echo ""
fi

# =============================================================================
# Frontend checks (only if frontend files changed)
# =============================================================================
if [ -n "$FRONTEND_CHANGED" ]; then
    echo -e "${YELLOW}━━━ Frontend Checks ━━━${NC}"

    # --- dart format check ---
    echo "🔧 Checking Dart formatting..."
    if (cd frontend && dart format --set-exit-if-changed .); then
        echo -e "${GREEN}  ✓ Dart formatting OK${NC}"
    else
        echo -e "${RED}  ✗ Dart formatting issues found${NC}"
        echo "  Run: cd frontend && dart format ."
        FAILED=1
    fi

    # --- flutter analyze ---
    echo "🔎 Running flutter analyze..."
    if (cd frontend && flutter analyze --no-pub); then
        echo -e "${GREEN}  ✓ Flutter analysis OK${NC}"
    else
        echo -e "${RED}  ✗ Flutter analysis found issues${NC}"
        FAILED=1
    fi

    # --- flutter test ---
    echo "🧪 Running Flutter tests..."
    if (cd frontend && flutter test); then
        echo -e "${GREEN}  ✓ Flutter tests passed${NC}"
    else
        echo -e "${RED}  ✗ Flutter tests failed${NC}"
        FAILED=1
    fi

    echo ""
fi

# =============================================================================
# Final result
# =============================================================================
if [ -z "$BACKEND_CHANGED" ] && [ -z "$FRONTEND_CHANGED" ] && [ -z "$YAML_FILES" ] && [ -z "$MD_FILES" ]; then
    echo -e "${GREEN}No backend, frontend, or YAML changes — skipping checks.${NC}"
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo -e "${RED}━━━ Pre-commit checks FAILED ━━━${NC}"
    echo -e "${RED}Fix the issues above before committing.${NC}"
    echo -e "Tip: Use ${YELLOW}git commit --no-verify${NC} to skip (not recommended)."
    exit 1
fi

echo -e "${GREEN}━━━ All pre-commit checks passed ✓ ━━━${NC}"
exit 0
