#!/bin/bash

# =============================================================================
# Pre-commit hook for WordUpX
# Runs format checks and tests for changed files before allowing commits.
# Only checks backend or frontend if relevant files were modified.
# =============================================================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "ЁЯФН Running pre-commit checks..."
echo ""

# Detect which areas have staged changes
BACKEND_CHANGED=$(git diff --cached --name-only -- 'backend-api/' | head -1)
FRONTEND_CHANGED=$(git diff --cached --name-only -- 'frontend/' | head -1)
# Exclude auto-generated swagger.yaml from YAML lint
YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.yml' '*.yaml' | grep -v 'backend-api/docs/swagger.yaml' || true)

FAILED=0

# =============================================================================
# YAML lint (only if .yml/.yaml files changed)
# =============================================================================
if [ -n "$YAML_FILES" ]; then
    echo -e "${YELLOW}тФБтФБтФБ YAML Checks тФБтФБтФБ${NC}"
    echo "ЁЯУЛ Linting YAML files..."

    if command -v yamllint &> /dev/null; then
        YAML_FAILED=0
        for file in $YAML_FILES; do
            if yamllint -d "{extends: default, rules: {line-length: {max: 200}, truthy: disable}}" "$file" 2>&1; then
                echo -e "${GREEN}  тЬУ $file${NC}"
            else
                YAML_FAILED=1
            fi
        done
        if [ $YAML_FAILED -ne 0 ]; then
            echo -e "${RED}  тЬЧ YAML lint issues found${NC}"
            FAILED=1
        else
            echo -e "${GREEN}  тЬУ All YAML files OK${NC}"
        fi
    else
        echo -e "${YELLOW}  тЪа yamllint not found тАФ skipping (install: pip install yamllint)${NC}"
    fi

    echo ""
fi

# =============================================================================
# Backend checks (only if backend files changed)
# =============================================================================
if [ -n "$BACKEND_CHANGED" ]; then
    echo -e "${YELLOW}тФБтФБтФБ Backend Checks тФБтФБтФБ${NC}"

    # --- Swagger docs generation ---
    echo "ЁЯУЭ Generating Swagger docs..."
    cd backend-api || exit 1
    if make swagger-prod; then
        git add docs/
        git add main.go
        echo -e "${GREEN}  тЬУ Swagger docs updated and staged${NC}"
    else
        echo -e "${RED}  тЬЧ Swagger doc generation failed${NC}"
        FAILED=1
    fi
    cd ..

    # --- gofmt check ---
    echo "ЁЯФз Checking Go formatting..."
    UNFORMATTED=$(gofmt -l backend-api/)
    if [ -z "$UNFORMATTED" ]; then
        echo -e "${GREEN}  тЬУ Go formatting OK${NC}"
    else
        echo -e "${RED}  тЬЧ Go formatting issues found:${NC}"
        echo "$UNFORMATTED"
        echo "  Run: gofmt -w backend-api/"
        FAILED=1
    fi

    # --- go vet ---
    echo "ЁЯФО Running go vet..."
    if (cd backend-api && go vet ./...); then
        echo -e "${GREEN}  тЬУ go vet OK${NC}"
    else
        echo -e "${RED}  тЬЧ go vet found issues${NC}"
        FAILED=1
    fi

    # --- go build ---
    echo "ЁЯФи Checking Go build..."
    if (cd backend-api && go build ./...); then
        echo -e "${GREEN}  тЬУ Go build OK${NC}"
    else
        echo -e "${RED}  тЬЧ Go build failed${NC}"
        FAILED=1
    fi

    # --- go test (unit) ---
    echo "ЁЯзк Running Go unit tests..."
    if (cd backend-api && go test ./tests/unit/... 2>&1); then
        echo -e "${GREEN}  тЬУ Go unit tests passed${NC}"
    else
        echo -e "${RED}  тЬЧ Go unit tests failed${NC}"
        FAILED=1
    fi

    # --- go test (integration) ---
    echo "ЁЯзк Running Go integration tests..."
    if (cd backend-api && go test ./tests/integration/... 2>&1); then
        echo -e "${GREEN}  тЬУ Go integration tests passed${NC}"
    else
        echo -e "${RED}  тЬЧ Go integration tests failed${NC}"
        FAILED=1
    fi

    echo ""
fi

# =============================================================================
# Frontend checks (only if frontend files changed)
# =============================================================================
if [ -n "$FRONTEND_CHANGED" ]; then
    echo -e "${YELLOW}тФБтФБтФБ Frontend Checks тФБтФБтФБ${NC}"

    # --- dart format check ---
    echo "ЁЯФз Checking Dart formatting..."
    if (cd frontend && dart format --set-exit-if-changed .); then
        echo -e "${GREEN}  тЬУ Dart formatting OK${NC}"
    else
        echo -e "${RED}  тЬЧ Dart formatting issues found${NC}"
        echo "  Run: cd frontend && dart format ."
        FAILED=1
    fi

    # --- flutter analyze ---
    echo "ЁЯФО Running flutter analyze..."
    if (cd frontend && flutter analyze --no-pub); then
        echo -e "${GREEN}  тЬУ Flutter analysis OK${NC}"
    else
        echo -e "${RED}  тЬЧ Flutter analysis found issues${NC}"
        FAILED=1
    fi

    # --- flutter test ---
    echo "ЁЯзк Running Flutter tests..."
    if (cd frontend && flutter test); then
        echo -e "${GREEN}  тЬУ Flutter tests passed${NC}"
    else
        echo -e "${RED}  тЬЧ Flutter tests failed${NC}"
        FAILED=1
    fi

    echo ""
fi

# =============================================================================
# Final result
# =============================================================================
if [ -z "$BACKEND_CHANGED" ] && [ -z "$FRONTEND_CHANGED" ] && [ -z "$YAML_FILES" ]; then
    echo -e "${GREEN}No backend, frontend, or YAML changes тАФ skipping checks.${NC}"
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo -e "${RED}тФБтФБтФБ Pre-commit checks FAILED тФБтФБтФБ${NC}"
    echo -e "${RED}Fix the issues above before committing.${NC}"
    echo -e "Tip: Use ${YELLOW}git commit --no-verify${NC} to skip (not recommended)."
    exit 1
fi

echo -e "${GREEN}тФБтФБтФБ All pre-commit checks passed тЬУ тФБтФБтФБ${NC}"
exit 0
