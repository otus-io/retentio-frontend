#!/bin/bash

# =============================================================================
# Pre-push hook for WordUpX
# Prevents direct pushes to the main branch.
# All changes must go through pull requests.
# =============================================================================

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'

PROTECTED_BRANCH="main"
CURRENT_BRANCH=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

# Check if pushing to a protected branch
while read local_ref local_sha remote_ref remote_sha; do
    if echo "$remote_ref" | grep -q "refs/heads/${PROTECTED_BRANCH}$"; then
        echo ""
        echo -e "${RED}━━━ Push to '${PROTECTED_BRANCH}' blocked ━━━${NC}"
        echo -e "${RED}Direct pushes to '${PROTECTED_BRANCH}' are not allowed.${NC}"
        echo -e "${YELLOW}Please create a feature branch and open a pull request instead:${NC}"
        echo ""
        echo "  git checkout -b <branch-name>"
        echo "  git push -u origin <branch-name>"
        echo "  gh pr create"
        echo ""
        echo -e "To bypass (not recommended): ${YELLOW}git push --no-verify${NC}"
        exit 1
    fi
done

exit 0
