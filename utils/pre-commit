#!/bin/bash

# =============================================================================
# Pre-commit hook — Retentio Flutter repo (pubspec.yaml at git root)
# Runs format checks and tests before allowing commits.
# =============================================================================

set -e

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || REPO_ROOT=""
if [ -z "$REPO_ROOT" ] || [ ! -f "$REPO_ROOT/pubspec.yaml" ]; then
    echo "Error: pre-commit must run inside this git repo (expected pubspec.yaml at root)."
    exit 1
fi
cd "$REPO_ROOT"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "🔍 Running pre-commit checks..."
echo ""

# Staged paths to lint (exclude third_party — vendored upstream content).
# Use arrays so we never call markdownlint/yamllint with zero file args after word-splitting
# (which prints Usage: … and looks like a broken hook).
lint_yaml_list=()
while IFS= read -r f || [ -n "$f" ]; do
  [ -z "$f" ] && continue
  case "$f" in
    third_party/*) ;;
    *) lint_yaml_list+=("$f") ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.yml' '*.yaml' || true)

lint_md_list=()
while IFS= read -r f || [ -n "$f" ]; do
  [ -z "$f" ] && continue
  case "$f" in
    third_party/*) ;;
    *) lint_md_list+=("$f") ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM -- '*.md' '*.mdc' || true)

FAILED=0

# =============================================================================
# YAML lint (only if .yml/.yaml files changed)
# =============================================================================
if [ ${#lint_yaml_list[@]} -gt 0 ]; then
    echo -e "${YELLOW}━━━ YAML Checks ━━━${NC}"
    echo "📋 Linting YAML files..."

    if command -v yamllint &> /dev/null; then
        YAML_FAILED=0
        for file in "${lint_yaml_list[@]}"; do
            if yamllint -d "{extends: default, rules: {line-length: {max: 200}, truthy: disable}}" "$file" 2>&1; then
                echo -e "${GREEN}  ✓ $file${NC}"
            else
                YAML_FAILED=1
            fi
        done
        if [ $YAML_FAILED -ne 0 ]; then
            echo -e "${RED}  ✗ YAML lint issues found${NC}"
            FAILED=1
        else
            echo -e "${GREEN}  ✓ All YAML files OK${NC}"
        fi
    else
        echo -e "${YELLOW}  ⚠ yamllint not found — skipping (install: pip install yamllint)${NC}"
    fi

    echo ""
fi

# =============================================================================
# Markdown lint (only if .md/.mdc files changed)
# =============================================================================
if [ ${#lint_md_list[@]} -gt 0 ]; then
    echo -e "${YELLOW}━━━ Markdown Checks ━━━${NC}"
    echo "📋 Linting Markdown files..."

    if command -v markdownlint &> /dev/null; then
        if markdownlint --config .markdownlint.json "${lint_md_list[@]}" 2>&1; then
            echo -e "${GREEN}  ✓ Markdown lint OK${NC}"
        else
            echo -e "${RED}  ✗ Markdown lint issues found${NC}"
            FAILED=1
        fi
    elif command -v markdownlint-cli2 &> /dev/null; then
        if markdownlint-cli2 "${lint_md_list[@]}" 2>&1; then
            echo -e "${GREEN}  ✓ Markdown lint OK${NC}"
        else
            echo -e "${RED}  ✗ Markdown lint issues found${NC}"
            FAILED=1
        fi
    else
        echo -e "${YELLOW}  ⚠ markdownlint not found — skipping (install: npm install -g markdownlint-cli)${NC}"
    fi

    echo ""
fi

# =============================================================================
# Dart / Flutter (always run — app lives at repo root next to pubspec.yaml)
# =============================================================================
echo -e "${YELLOW}━━━ Dart / Flutter ━━━${NC}"

echo "🔧 Checking Dart formatting..."
if (dart format --set-exit-if-changed .); then
    echo -e "${GREEN}  ✓ Dart formatting OK${NC}"
else
    echo -e "${RED}  ✗ Dart formatting issues found${NC}"
    echo "  Run: dart format ."
    FAILED=1
fi

# --- flutter analyze ---
echo "🔎 Running flutter analyze..."
if (flutter analyze --no-pub); then
    echo -e "${GREEN}  ✓ Flutter analysis OK${NC}"
else
    echo -e "${RED}  ✗ Flutter analysis found issues${NC}"
    FAILED=1
fi

# --- flutter test ---
echo "🧪 Running Flutter tests..."
if (flutter test); then
    echo -e "${GREEN}  ✓ Flutter tests passed${NC}"
else
    echo -e "${RED}  ✗ Flutter tests failed${NC}"
    FAILED=1
fi

echo ""

# =============================================================================
# Final result
# =============================================================================
if [ ${#lint_yaml_list[@]} -eq 0 ] && [ ${#lint_md_list[@]} -eq 0 ]; then
    echo -e "${GREEN}No YAML or Markdown in this commit — only Dart / Flutter checks ran.${NC}"
fi

if [ $FAILED -ne 0 ]; then
    echo ""
    echo -e "${RED}━━━ Pre-commit checks FAILED ━━━${NC}"
    echo -e "${RED}Fix the issues above before committing.${NC}"
    echo -e "Tip: Use ${YELLOW}git commit --no-verify${NC} to skip (not recommended)."
    exit 1
fi

echo -e "${GREEN}━━━ All pre-commit checks passed ✓ ━━━${NC}"
exit 0
