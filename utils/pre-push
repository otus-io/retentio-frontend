#!/bin/bash

# =============================================================================
# pre-push hook — validate local git workflow conventions before pushing
# =============================================================================

set -e

REMOTE_NAME="$1"
REMOTE_URL="$2"

# shellcheck disable=SC2034
REMOTE_NAME="$REMOTE_NAME"
# shellcheck disable=SC2034
REMOTE_URL="$REMOTE_URL"

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || REPO_ROOT=""
if [ -z "$REPO_ROOT" ]; then
  echo "Error: pre-push must run inside a git repository."
  exit 1
fi
cd "$REPO_ROOT"

CURRENT_BRANCH="$(git branch --show-current)"
if [ -z "$CURRENT_BRANCH" ]; then
  echo "✗ Could not determine current branch."
  exit 1
fi

if [ "$CURRENT_BRANCH" = "main" ]; then
  echo "✗ Pushing directly to 'main' is not allowed. Please use a feature branch + PR."
  exit 1
fi

# Allow slashes for prefixes (e.g., codex/feature-name) while enforcing lowercase + hyphen chunks.
if [[ ! "$CURRENT_BRANCH" =~ ^[a-z0-9]+([/-][a-z0-9]+)*$ ]]; then
  echo "✗ Invalid branch name: '$CURRENT_BRANCH'"
  echo "  Use lowercase and hyphens (slashes allowed as prefixes), e.g.:"
  echo "  codex/frontend-auth-flow, deck-card-ui"
  exit 1
fi

BASE_REF="origin/main"
if ! git show-ref --verify --quiet "refs/remotes/$BASE_REF"; then
  echo "⚠ $BASE_REF not found locally. Fetching from origin..."
  git fetch origin main --quiet
fi

if ! git show-ref --verify --quiet "refs/remotes/$BASE_REF"; then
  echo "✗ Cannot find $BASE_REF after fetch. Aborting push checks."
  exit 1
fi

COMMITS_AHEAD="$(git rev-list --count "${BASE_REF}..HEAD")"
if [ "$COMMITS_AHEAD" -gt 3 ]; then
  echo "✗ This branch has $COMMITS_AHEAD commits ahead of $BASE_REF (limit: 3)."
  echo "  Please squash/split before pushing."
  exit 1
fi

# Count changed lines excluding tests and common generated/lock files.
DIFF_STATS="$(
  git diff --numstat "${BASE_REF}...HEAD" \
    ':(exclude)test/**' \
    ':(exclude)**/*.g.dart' \
    ':(exclude)**/*.freezed.dart' \
    ':(exclude)**/*.gen.dart' \
    ':(exclude)pubspec.lock' \
    ':(exclude)**/*.lock' || true
)"

TOTAL_LINES=0
if [ -n "$DIFF_STATS" ]; then
  while IFS=$'\t' read -r added deleted _path; do
    [ "$added" = "-" ] && added=0
    [ "$deleted" = "-" ] && deleted=0
    TOTAL_LINES=$((TOTAL_LINES + added + deleted))
  done <<< "$DIFF_STATS"
fi

if [ "$TOTAL_LINES" -gt 200 ]; then
  echo "✗ Effective PR size is $TOTAL_LINES lines (limit: 200, excluding tests/generated files)."
  echo "  Please split this branch into smaller PRs."
  exit 1
fi

echo "✓ Pre-push convention checks passed (branch, commits, PR size)."
exit 0
